# Required: Your TeleBotHost Developer API key (sk_* for write access, pub_* for read-only)
TELEBOTHOST_API_KEY=sk_your_secret_key_here

# Optional: Override the API base URL (defaults to https://api.telebothost.com/api/v1)
# TELEBOTHOST_API_BASE=https://api.telebothost.com/api/v1

# Optional: Protect your MCP endpoint with a shared secret.
# If set, clients must send "Authorization: Bearer <MCP_AUTH_TOKEN>" to access the MCP.
# This is separate from the TBH API key above.
# MCP_AUTH_TOKEN=your-mcp-access-token
