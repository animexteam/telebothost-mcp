{
  "name": "telebothost-mcp",
  "version": "1.4.0",
  "description": "TeleBotHost Developer API MCP Server — Model Context Protocol server for the TeleBotHost Developer API. Runs locally via stdio (Claude Desktop, Cursor, VS Code).",
  "type": "module",
  "main": "bin/mcp.js",
  "bin": {
    "telebothost-mcp": "./bin/mcp.js"
  },
  "scripts": {
    "start": "node --import tsx bin/mcp.ts",
    "dev": "node --import tsx --watch bin/mcp.ts",
    "serve:http": "node --import tsx server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bash scripts/test-mcp.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "telebothost",
    "telegram-bot",
    "telegram",
    "ai",
    "claude",
    "cursor",
    "stdio",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://github.com/sahilxteam/telebothost-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sahilxteam/telebothost-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/sahilxteam/telebothost-mcp/issues"
  }
}
